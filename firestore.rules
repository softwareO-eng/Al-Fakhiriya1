rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /entities/{document=**} {
      allow read, write: if true;
    }

    match /documents/{document=**} {
      allow read, write: if true;
    }

    match /system/{document=**} {
      allow read, write: if true;
    }
  }
}
